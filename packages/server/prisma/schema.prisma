generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Placeholder model so `prisma migrate dev --name init` creates _prisma_migrations.
// Will be replaced with real domain models starting Phase 1.
model HealthCheck {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  @@map("health_checks")
}

enum ScheduleStatus {
  pending
  recording
  completed
  failed
  cancelled
}

enum RecordingStatus {
  recording
  completed
  failed
}

enum RuleKeywordMode {
  literal
  regex
}

enum RuleKeywordTarget {
  title
  title_description
}

enum RuleEncodeCodec {
  avc
  hevc
  vp9
}

enum RuleEncodeQuality {
  high
  medium
  low
}

enum RuleEncodeTiming {
  immediate
  idle
}

enum HwAccelType {
  cpu
  nvenc
  vaapi
}

model EncodeProfile {
  id        String            @id @default(uuid())
  name      String            @unique
  codec     RuleEncodeCodec   @default(avc)
  quality   RuleEncodeQuality @default(medium)
  timing    RuleEncodeTiming  @default(immediate)
  hwAccel   HwAccelType       @default(cpu)   @map("hw_accel")
  isDefault Boolean           @default(false) @map("is_default")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt      @map("updated_at")

  rules     RecordingRule[]
  schedules RecordingSchedule[]

  @@index([isDefault])
  @@map("encode_profiles")
}

model Program {
  id          String   @id
  channelId   String   @map("channel_id")
  title       String
  description String?
  startAt     DateTime @map("start_at") @db.Timestamptz
  endAt       DateTime @map("end_at")   @db.Timestamptz
  genres      String[] @default([])
  updatedAt   DateTime @updatedAt @map("updated_at")
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@index([channelId, startAt])
  @@index([startAt, endAt])
  @@index([title])
  @@map("programs")
}

model RecordingRule {
  id                 String             @id @default(uuid())
  name               String
  enabled            Boolean            @default(true)
  keyword            String?
  keywordMode        RuleKeywordMode    @default(literal) @map("keyword_mode")
  keywordTarget      RuleKeywordTarget  @default(title)   @map("keyword_target")
  excludeKeyword     String?            @map("exclude_keyword")
  channelIds         String[]           @default([]) @map("channel_ids")
  genres             String[]           @default([])
  dayOfWeek          Int[]              @default([]) @map("day_of_week")
  timeStartMinutes   Int?               @map("time_start_minutes")
  timeEndMinutes     Int?               @map("time_end_minutes")
  priority           Int                @default(0)
  avoidDuplicates    Boolean            @default(true) @map("avoid_duplicates")
  excludeReruns      Boolean            @default(false) @map("exclude_reruns")
  newOnly            Boolean            @default(false) @map("new_only")
  marginStartMinutes Int                @default(0)     @map("margin_start_minutes")
  marginEndMinutes   Int                @default(0)     @map("margin_end_minutes")
  minDurationMinutes Int                @default(0)     @map("min_duration_minutes")
  keepLatestN        Int                @default(0)     @map("keep_latest_n")
  encodeProfileId    String?            @map("encode_profile_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt      @map("updated_at")

  schedules     RecordingSchedule[]
  encodeProfile EncodeProfile? @relation(fields: [encodeProfileId], references: [id], onDelete: SetNull)

  @@index([enabled])
  @@index([encodeProfileId])
  @@map("recording_rules")
}

model RecordingSchedule {
  id              String         @id @default(uuid())
  channelId       String         @map("channel_id")
  programId       String         @map("program_id")
  title           String
  startAt         DateTime       @map("start_at") @db.Timestamptz
  endAt           DateTime       @map("end_at") @db.Timestamptz
  status          ScheduleStatus @default(pending)
  ruleId          String?        @map("rule_id")
  encodeProfileId String?        @map("encode_profile_id")
  failureReason   String?        @map("failure_reason")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  recording     Recording?
  rule          RecordingRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  encodeProfile EncodeProfile? @relation(fields: [encodeProfileId], references: [id], onDelete: SetNull)

  @@unique([ruleId, programId])
  @@index([status, startAt])
  @@index([ruleId])
  @@index([encodeProfileId])
  @@map("recording_schedules")
}

model Recording {
  id           String          @id @default(uuid())
  scheduleId   String          @unique @map("schedule_id")
  channelId    String          @map("channel_id")
  title        String
  startedAt    DateTime        @map("started_at") @db.Timestamptz
  endedAt      DateTime?       @map("ended_at") @db.Timestamptz
  filePath     String?         @map("file_path")
  sizeBytes    BigInt?         @map("size_bytes")
  durationSec  Int?            @map("duration_sec")
  thumbnailUrl String?         @map("thumbnail_url")
  status       RecordingStatus
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  schedule RecordingSchedule @relation(fields: [scheduleId], references: [id])

  @@index([status, startedAt])
  @@map("recordings")
}
