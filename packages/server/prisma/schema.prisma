generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Placeholder model so `prisma migrate dev --name init` creates _prisma_migrations.
// Will be replaced with real domain models starting Phase 1.
model HealthCheck {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  @@map("health_checks")
}
