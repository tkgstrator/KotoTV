{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bunx @biomejs/biome *)",
      "Bash(bunx --bun @biomejs/biome *)",
      "Bash(bunx biome *)",
      "Bash(bun run *)",
      "Bash(bun install *)",
      "Bash(bun add *)",
      "Bash(bunx tsc *)",
      "Bash(bunx prisma *)",
      "Bash(bunx shadcn *)",
      "Bash(docker compose config)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; [ -n \"$f\" ] && bunx --bun @biomejs/biome check --write --no-errors-on-unmatched \"$f\"; } 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Biome (auto-fix)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx --bun @biomejs/biome check --no-errors-on-unmatched . 2>&1 | tail -40; [ -f tsconfig.base.json ] && bunx tsc -b --noEmit 2>&1 | tail -40; true",
            "timeout": 120,
            "statusMessage": "Biome + tsc (repo check)",
            "async": true
          }
        ]
      }
    ]
  },
  "model": "claude-opus-4-6",
  "enabledMcpjsonServers": [
    "docker",
    "github",
    "tailwindcss",
    "shadcn",
    "prisma",
    "zod"
  ],
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
