# ─── Server ───────────────────────────────────────────────────────────────────
# Port the app listens on inside the container.
PORT=11575

# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string.
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:password@postgres:5432/koto

# ─── Mirakc ───────────────────────────────────────────────────────────────────
# Base URL of the mirakc REST API (no trailing slash).
MIRAKC_URL=http://mirakc:40772

# ─── Hardware Acceleration ────────────────────────────────────────────────────
# Selects the FFmpeg hardware encoder backend.
#   none   — software encode (libx264 / libx265 / libvpx-vp9)
#   nvenc  — NVIDIA NVENC  (requires nvidia-container-toolkit on host)
#   qsv    — Intel Quick Sync Video (requires /dev/dri passthrough)
#   vaapi  — VA-API / Mesa  (requires /dev/dri passthrough)
HW_ACCEL_TYPE=none

# ─── Transcode Codec ──────────────────────────────────────────────────────────
# Preferred output codec for HLS segments.
#   avc   — H.264  (widest compatibility, iOS / Safari fallback)
#   hevc  — H.265  (iOS Safari native, ~50 % smaller than AVC)
#   vp9   — VP9    (modern browsers, royalty-free)
# The streaming service selects the codec per session; this env sets the default.
CODEC=avc

# ─── Postgres (prod container) ────────────────────────────────────────────────
# Used by the postgres service in docker-compose.yml.
POSTGRES_PASSWORD=changeme
